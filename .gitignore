# ── Raw data ── ~16 GB of inputs (311_data.csv is 14 GB). NEVER commit.
# Reproduce by dropping the source files back into data/ (see README "Reproducing").
data/

# ── Build artifacts ── regenerated by the pipeline; stored externally
# (GitHub Releases / object storage), not in git history.
output/

# ── Serving bundle ── generated by scripts/build_serving_bundle.py
serving/data/
serving/tiles/

# ── Python ──
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/

# ── Secrets / local config ──
.env
.env.*
!.env.example
.streamlit/secrets.toml

# ── OS / editor ──
.DS_Store
*.swp
.idea/
.vscode/
