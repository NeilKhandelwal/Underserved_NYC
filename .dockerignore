# Minimal build context: ignore everything, then allow only the paths the
# Dockerfile actually COPYs. This keeps the context small/fast and — on macOS —
# avoids forcing Docker to read unrelated iCloud-evicted ("dataless") files,
# which makes "load build context" crawl/hang.
*

# Paths the Dockerfile needs (see COPY lines in ./Dockerfile)
!api/
!scripts/
!output/
!frontend/
!requirements-api.txt

# Re-exclude heavy/derived subdirs that live inside the allowed dirs
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Caches / compiled junk that can appear under allowed dirs
**/__pycache__/
**/*.pyc
**/.DS_Store
